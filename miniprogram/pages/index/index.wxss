/* pages/index/index.wxss */
.container {
  padding: 20rpx;
}

.news-item {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.news-header {
  padding: 30rpx;
  /* active 状态下背景微调 */
}

.news-header:active {
  background-color: #f9f9f9;
}

.news-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.news-title.active {
  color: #D7000F; /* 孙颖莎红 */
}

.news-meta {
  display: flex;
  font-size: 24rpx;
  color: #999;
  align-items: center;
}

.news-source {
  margin-right: 20rpx;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  color: #666;
}

.news-time {
  flex: 1;
}

.expand-icon {
  color: #D7000F;
}

.news-summary {
  padding: 0 30rpx 30rpx;
  border-top: 1rpx solid #eee;
  background-color: #fafafa;
  font-size: 30rpx;
  line-height: 1.6;
  color: #444;
  padding-top: 20rpx;
}

/* Markdown 样式适配 */
.news-summary image {
  max-width: 100%;
  border-radius: 8rpx;
  margin: 10rpx 0;
}
